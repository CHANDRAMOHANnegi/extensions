{
    "manifest_version": 3,
    "name": "Focus Blocker",
    "version": "1.0",
    "description": "Block distracting websites to stay focused",
    "permissions": [
        "storage",
        "tabs",
        "webNavigation"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    }
}